<UserControl x:Class="Uno.Views.SavesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FAFAFA">

    <Grid>
        <Border Background="White" Width="550" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="12" Padding="40,30" Margin="20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.08" BlurRadius="25" ShadowDepth="4"/>
            </Border.Effect>

            <StackPanel>
                <Button Command="{Binding VoltarCommand}" Content="&lt; Voltar ao menu" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Foreground="#888888" FontSize="14" Cursor="Hand" Margin="-5,0,0,20"/>

                <TextBlock Text="Saves Disponíveis" FontSize="26" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,5"/>
                <TextBlock Text="Escolhe um jogo para retomar de onde ficaste" Foreground="#888888" FontSize="14" Margin="0,0,0,20"/>

                <ListBox ItemsSource="{Binding ListaSaves}" Height="300" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,5,0,5" Width="460">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding}" FontWeight="Bold" FontSize="16" Foreground="#444444"/>
                                        <TextBlock Text="Ficheiro XML" Foreground="Gray" FontSize="12"/>
                                    </StackPanel>

                                    <Button Grid.Column="1" Command="{Binding DataContext.CarregarSaveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Content="Jogar" Background="#2A9D8F" Foreground="White" Width="80" Height="35" Margin="0,0,10,0" Style="{StaticResource RoundedButtonStyle}"/>
                                    <Button Grid.Column="2" Command="{Binding DataContext.ApagarSaveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Content="X" Background="#E63946" Foreground="White" Width="35" Height="35" Style="{StaticResource RoundedButtonStyle}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>