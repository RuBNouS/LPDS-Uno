<UserControl x:Class="Uno.Views.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FAFAFA">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">

            <Border Background="#E63946" CornerRadius="10" Width="100" Height="60" Margin="0,0,0,20">
                <TextBlock Text="UNO" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Bem-vindo de volta" FontSize="24" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Inicia um novo jogo ou entra numa sala existente" FontSize="14" Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="Número de bots:" VerticalAlignment="Center" Foreground="#555555" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding OpcoesBots}" SelectedItem="{Binding NumeroBots}" Width="60" Padding="5"/>
            </StackPanel>

            <Button Command="{Binding CriarNovoJogoCommand}" Content="Novo Jogo" 
                    Background="#E63946" Foreground="White" Height="45" FontSize="16" FontWeight="SemiBold" 
                    Margin="0,0,0,15" Style="{StaticResource RoundedButtonStyle}"/>

            <Button Command="{Binding RetomarPartidaCommand}" Content="Saves Guardados" 
                    Background="White" Foreground="#333333" BorderBrush="#DDDDDD" BorderThickness="1" 
                    Height="45" FontSize="16" Margin="0,0,0,15" Style="{StaticResource RoundedButtonStyle}"/>

            <Button Command="{Binding VerRegrasCommand}" Content="Ver regras do UNO" 
                    Background="White" Foreground="#333333" BorderBrush="#DDDDDD" BorderThickness="1" 
                    Height="45" FontSize="16" Margin="0,0,0,15" Style="{StaticResource RoundedButtonStyle}"/>

            <Button Command="{Binding ConsultarEstatisticasCommand}" Content="Consultar Estatísticas" 
                    Background="White" Foreground="#333333" BorderBrush="#DDDDDD" BorderThickness="1" 
                    Height="45" FontSize="16" Style="{StaticResource RoundedButtonStyle}"/>

        </StackPanel>
    </Grid>
</UserControl>