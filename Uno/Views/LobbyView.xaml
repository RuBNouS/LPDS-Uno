<UserControl x:Class="Uno.Views.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="white">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" Margin="20">

            <Border Background="red" CornerRadius="10" Width="100" Height="60" Margin="0,0,0,20">
                <TextBlock Text="UNO" Foreground="White" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Bem-vindo de volta" FontSize="25" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10" >
                <TextBlock Text="Número de bots:" FontSize="15" VerticalAlignment="Center" Foreground="black" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding OpcoesBots}" SelectedItem="{Binding NumeroBots}" Width="60" Padding="5"/>
            </StackPanel>

            <Button Command="{Binding CriarNovoJogoCommand}" Content="Novo Jogo" 
                    Background="red" Foreground="White" BorderBrush="black" BorderThickness="1" 
                    Height="45" FontSize="20" Margin="0,0,0,15"
                    Style="{StaticResource RoundedButtonStyle}"/>

            <Button Command="{Binding RetomarPartidaCommand}" Content="Saves Guardados" 
                    Background="White" Foreground="black" BorderBrush="black" BorderThickness="1" 
                    Height="45" FontSize="20" Margin="0,0,0,15"
                    Style="{StaticResource RoundedButtonStyle}"/>

            <Button Command="{Binding VerRegrasCommand}" Content="Ver regras do UNO" 
                    Background="White" Foreground="black" BorderBrush="black" BorderThickness="1"  
                    Height="45" FontSize="20" Margin="0,0,0,15"
                    Style="{StaticResource RoundedButtonStyle}"/>

            <Button Command="{Binding ConsultarEstatisticasCommand}" Content="Consultar Estatísticas" 
                    Background="White" Foreground="black" BorderBrush="black" BorderThickness="1"  
                    Height="45" FontSize="20" Margin="0,0,0,0"
                    Style="{StaticResource RoundedButtonStyle}"/>

        </StackPanel>
    </Grid>
</UserControl>