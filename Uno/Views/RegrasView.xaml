<UserControl x:Class="Uno.Views.RegrasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FAFAFA">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Background="White" Width="550" VerticalAlignment="Top" HorizontalAlignment="Center" CornerRadius="12" Padding="40,30" Margin="0,30,0,30">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.08" BlurRadius="25" ShadowDepth="4"/>
            </Border.Effect>

            <StackPanel>
                <Button Command="{Binding VoltarCommand}" Content="&lt; Voltar ao menu principal" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Foreground="#888888" FontSize="14" Cursor="Hand" Margin="-5,0,0,20"/>

                <TextBlock Text="Regras do UNO" FontSize="26" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,5"/>
                <TextBlock Text="Aprende a jogar em poucos passos" Foreground="#888888" FontSize="14" Margin="0,0,0,30"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Width="8" Height="8" Fill="#E63946" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Objetivo" FontWeight="Bold" Foreground="#444444"/>
                </StackPanel>
                <TextBlock Text="Ser o primeiro jogador a descartar todas as cartas da mão. O jogo pode ter várias rondas; os pontos acumulam-se com as cartas que os adversários ainda têm." TextWrapping="Wrap" Margin="18,0,0,20" Foreground="#666666" LineHeight="20"/>

                <Separator Margin="0,5,0,20" Background="#EEEEEE"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Width="8" Height="8" Fill="#457B9D" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Como jogar" FontWeight="Bold" Foreground="#444444"/>
                </StackPanel>
                <TextBlock Text="No teu turno, joga uma carta que corresponda à cor ou ao número da carta no topo da pilha de descarte. Se não tiveres nenhuma carta válida, retira uma carta do baralho." TextWrapping="Wrap" Margin="18,0,0,20" Foreground="#666666" LineHeight="20"/>

                <Separator Margin="0,5,0,20" Background="#EEEEEE"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Width="8" Height="8" Fill="#2A9D8F" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Cartas especiais" FontWeight="Bold" Foreground="#444444"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="18,10,0,15">
                    <Border Background="#E63946" Width="60" Height="45" CornerRadius="6" Margin="0,0,10,0">
                        <TextBlock Text="⇄" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="Bold"/>
                    </Border>
                    <Border Background="#457B9D" Width="60" Height="45" CornerRadius="6" Margin="0,0,10,0">
                        <TextBlock Text="Ø" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" FontWeight="Bold"/>
                    </Border>
                    <Border Background="#D4A338" Width="60" Height="45" CornerRadius="6" Margin="0,0,10,0">
                        <TextBlock Text="+2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    </Border>
                    <Border Background="#333333" Width="70" Height="45" CornerRadius="6" Margin="0,0,10,0">
                        <TextBlock Text="Wild Card" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"/>
                    </Border>
                    <Border Background="#333333" Width="60" Height="45" CornerRadius="6">
                        <TextBlock Text="+4" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <TextBlock Text="Inverter, Bloquear, +2, Wild Card e Wild +4." TextWrapping="Wrap" Margin="18,0,0,20" Foreground="#666666"/>

                <Separator Margin="0,5,0,20" Background="#EEEEEE"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Width="8" Height="8" Fill="#D4A338" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="UNO!" FontWeight="Bold" Foreground="#444444"/>
                </StackPanel>
                <TextBlock Text="Quando te restar apenas uma carta, deves dizer &quot;UNO!&quot;. Se não o fizeres e outro jogador se aperceber, tens de comprar 2 cartas." TextWrapping="Wrap" Margin="18,0,0,20" Foreground="#666666" LineHeight="20"/>

                <Separator Margin="0,5,0,20" Background="#EEEEEE"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Width="8" Height="8" Fill="#333333" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Wild Card" FontWeight="Bold" Foreground="#444444"/>
                </StackPanel>
                <TextBlock Text="Ao jogar uma Wild Card, escolhes a cor que o jogo continua. A Wild +4 obriga o próximo jogador a comprar 4 cartas e perde o turno." TextWrapping="Wrap" Margin="18,0,0,10" Foreground="#666666" LineHeight="20"/>

            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>