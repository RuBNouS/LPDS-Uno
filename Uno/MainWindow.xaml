<Window x:Class="Uno.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Uno.ViewModels"
        Title="Jogo UNO Digital" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="20" Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="Iniciar Nova Partida" Command="{Binding IniciarPartidaCommand}" 
                Padding="15" FontSize="16" FontWeight="Bold" Background="#E21B22" Foreground="White"
                HorizontalAlignment="Center" Width="200" Cursor="Hand"/>

        <Border Grid.Row="1" Background="#228B22" CornerRadius="10" Margin="0,20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="CARTA NA MESA" Foreground="White" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Border Width="100" Height="150" CornerRadius="8" BorderBrush="White" BorderThickness="3">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#DDDDDD"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding JogoAtual.Mesa.CartasJogadas[0].Cor}" Value="Vermelho">
                                    <Setter Property="Background" Value="#E21B22"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding JogoAtual.Mesa.CartasJogadas[0].Cor}" Value="Amarelo">
                                    <Setter Property="Background" Value="#F9E200"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding JogoAtual.Mesa.CartasJogadas[0].Cor}" Value="Verde">
                                    <Setter Property="Background" Value="#51A331"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding JogoAtual.Mesa.CartasJogadas[0].Cor}" Value="Azul">
                                    <Setter Property="Background" Value="#0072BC"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding JogoAtual.Mesa.CartasJogadas[0].Cor}" Value="Preto">
                                    <Setter Property="Background" Value="#222222"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding JogoAtual.Mesa.CartasJogadas[0].Simbolo, FallbackValue='?'}" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" FontWeight="Bold" Foreground="White"/>
                </Border>

                <TextBlock Text="{Binding JogoAtual.Mesa.Baralho.NumeroCartasRestantes, StringFormat='Cartas no Baralho: {0}'}" 
                           Foreground="White" HorizontalAlignment="Center" Margin="0,15,0,0" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <ItemsControl Grid.Row="2" ItemsSource="{Binding JogoAtual.Jogadores}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="{Binding Nome}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Foreground="#333333"/>
                            <TextBlock Text="{Binding Cartas.Count, StringFormat='{}Cartas na mão: {0}'}" HorizontalAlignment="Center" Foreground="#888888" Margin="0,0,0,10"/>

                            <ItemsControl ItemsSource="{Binding Cartas}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBot}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="40" Height="60" CornerRadius="4" Margin="2" BorderBrush="Black" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Cor}" Value="Vermelho">
                                                            <Setter Property="Background" Value="#E21B22"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Cor}" Value="Amarelo">
                                                            <Setter Property="Background" Value="#F9E200"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Cor}" Value="Verde">
                                                            <Setter Property="Background" Value="#51A331"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Cor}" Value="Azul">
                                                            <Setter Property="Background" Value="#0072BC"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Cor}" Value="Preto">
                                                            <Setter Property="Background" Value="#222222"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Simbolo}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="10" TextWrapping="Wrap" TextAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding Cartas}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBot}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="2" Cursor="Hand"
                                                Command="{Binding DataContext.JogarCartaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Button.Template>

                                            <Border Width="45" Height="65" CornerRadius="4" BorderBrush="Black" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Cor}" Value="Vermelho">
                                                                <Setter Property="Background" Value="#E21B22"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Cor}" Value="Amarelo">
                                                                <Setter Property="Background" Value="#F9E200"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Cor}" Value="Verde">
                                                                <Setter Property="Background" Value="#51A331"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Cor}" Value="Azul">
                                                                <Setter Property="Background" Value="#0072BC"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Cor}" Value="Preto">
                                                                <Setter Property="Background" Value="#222222"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Simbolo}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"/>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>